@model IEnumerable<NeonBank.Models.SupportMessage>
@{
    ViewData["Title"] = "Support Inbox";
}

<div class="container mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="fw-bold mb-0" style="color: #002d72;">
                <i class="bi bi-envelope-open me-2"></i>Support Inbox
            </h2>
            <small class="text-muted">@Model.Count() message(s) received</small>
        </div>
        <a asp-controller="Banking" asp-action="AdminDashboard" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Back to Admin Panel
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
            <p class="mt-3">No support messages received yet.</p>
        </div>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var msg in Model)
            {
                <div class="list-group-item list-group-item-action p-4 @(msg.IsRead ? "" : "border-start border-4 border-primary")">
                    <div class="d-flex w-100 justify-content-between align-items-start">
                        <h5 class="mb-1 fw-bold" style="color: #002d72;">
                            @if (!msg.IsRead)
                            {
                                <span class="badge bg-primary me-2 small">NEW</span>
                            }
                            @msg.Subject
                        </h5>
                        <small class="text-muted text-nowrap ms-3">
                            <i class="bi bi-clock me-1"></i>@msg.SentDate.ToString("MMM dd, yyyy HH:mm")
                        </small>
                    </div>
                    <p class="mb-2 text-dark mt-2">@msg.MessageContent</p>
                    <small class="text-primary fw-bold">
                        <i class="bi bi-person me-1"></i>From: @msg.SenderName
                    </small>
                </div>
            }
        </div>
    }
</div>
