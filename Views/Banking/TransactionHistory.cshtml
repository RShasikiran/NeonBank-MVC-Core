@model IEnumerable<NeonBank.Models.Transaction>
@{
    ViewData["Title"] = "Transaction Statement";
}

<div class="container mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h2 class="fw-bold mb-0" style="color: #002d72;">
                <i class="bi bi-file-earmark-text me-2"></i>Account Statement
            </h2>
            <small class="text-muted">Complete transaction history for your account</small>
        </div>
        <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">
            <i class="bi bi-printer me-1"></i>Print Statement
        </button>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 12px; overflow: hidden;">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox" style="font-size: 3rem;"></i>
                    <p class="mt-3 mb-0">No transactions found in your account yet.</p>
                    <a asp-controller="Banking" asp-action="Dashboard" class="btn btn-bank btn-sm mt-3">Make a Transfer</a>
                </div>
            }
            else
            {
                <table class="table table-hover mb-0 align-middle">
                    <thead style="background-color: #002d72; color: white;">
                        <tr>
                            <th class="ps-4 py-3">Date & Time</th>
                            <th>Description</th>
                            <th>Type</th>
                            <th class="text-end pe-4">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tx in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="fw-bold">@tx.TransactionDate.ToString("MMM dd, yyyy")</span><br />
                                    <small class="text-muted">@tx.TransactionDate.ToString("HH:mm")</small>
                                </td>
                                <td>@tx.Description</td>
                                <td>
                                    @if (tx.Type.Contains("Loan"))
                                    {
                                        <span class="badge bg-info text-dark">@tx.Type</span>
                                    }
                                    else if (tx.Amount < 0)
                                    {
                                        <span class="badge bg-light text-danger border">
                                            <i class="bi bi-arrow-up-right me-1"></i>Debit
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-success border">
                                            <i class="bi bi-arrow-down-left me-1"></i>Credit
                                        </span>
                                    }
                                </td>
                                <td class="text-end pe-4 fw-bold @(tx.Amount < 0 ? "text-danger" : "text-success")">
                                    @(tx.Amount < 0 ? "-" : "+")$@Math.Abs(tx.Amount).ToString("N2")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
