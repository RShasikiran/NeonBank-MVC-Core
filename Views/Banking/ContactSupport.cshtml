@{
    ViewData["Title"] = "Contact Support";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-7">
        <div class="card shadow border-0" style="border-radius: 14px; overflow: hidden;">
            <div style="background: linear-gradient(135deg, #002d72, #b2945e); padding: 25px; text-align: center;">
                <i class="bi bi-headset" style="font-size: 2.5rem; color: white;"></i>
                <h3 class="mt-2 fw-bold text-white">Secure Communication Channel</h3>
                <p class="text-white-50 small mb-0">Direct line to institutional support</p>
            </div>
            <div class="card-body p-5">
                <form asp-action="SendMessage" asp-controller="Banking" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="fw-bold">Subject</label>
                        <input name="subject" class="form-control" placeholder="e.g. Wire Transfer Inquiry" required />
                    </div>
                    <div class="mb-4">
                        <label class="fw-bold">Message Details</label>
                        <textarea name="message" class="form-control" rows="6"
                                  placeholder="Please describe your issue in detail..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-bank w-100 py-2">
                        <i class="bi bi-send me-2"></i>Send Message to Support
                    </button>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3">
                <small class="text-muted">
                    <i class="bi bi-clock me-1"></i>Typical response time: within 2–4 business hours
                </small>
            </div>
        </div>
    </div>
</div>
