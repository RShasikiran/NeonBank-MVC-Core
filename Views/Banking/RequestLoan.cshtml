@{
    ViewData["Title"] = "Loan Application";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow border-0" style="border-radius: 14px; overflow: hidden;">
            <div style="background: #002d72; padding: 25px; text-align: center;">
                <i class="bi bi-bank" style="font-size: 2.5rem; color: #b2945e;"></i>
                <h3 class="mt-2 fw-bold text-white">Institutional Loan Request</h3>
                <p class="text-white-50 small mb-0">Submit your credit application for admin review</p>
            </div>
            <div class="card-body p-5">
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    </div>
                }

                <div class="alert alert-info border-0" style="background: #e8f0ff;">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>How it works:</strong> Submit your loan request and an admin will review and approve the funds directly to your account.
                </div>

                <form asp-action="SubmitLoan" asp-controller="Banking" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="fw-bold">Requested Credit Amount (USD)</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text">$</span>
                            <input name="amount" type="number" step="0.01" min="1"
                                   class="form-control" placeholder="e.g. 5000.00" required />
                        </div>
                        <small class="text-muted">Minimum request: $1.00</small>
                    </div>
                    <button type="submit" class="btn btn-bank w-100 py-2">
                        <i class="bi bi-send me-2"></i>Submit Loan Application
                    </button>
                </form>
            </div>
            <div class="card-footer bg-light text-center py-3">
                <small class="text-muted">
                    <i class="bi bi-shield-check me-1"></i>All loan applications are reviewed within 24 business hours.
                </small>
            </div>
        </div>
    </div>
</div>
