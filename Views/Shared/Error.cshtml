@model NeonBank.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}
<div class="container mt-5 text-center">
    <i class="bi bi-exclamation-circle" style="font-size: 4rem; color: #dc3545;"></i>
    <h1 class="mt-3 fw-bold">Something went wrong</h1>
    <p class="text-muted">An unexpected error occurred. Please try again.</p>
    @if (Model.ShowRequestId)
    {
        <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-bank mt-3">
        <i class="bi bi-house me-2"></i>Return to Dashboard
    </a>
</div>
