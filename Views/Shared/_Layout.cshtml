<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>NeonBank — @ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root { --bank-blue: #002d72; --bank-gold: #b2945e; }
        body { background-color: #f4f6fb; color: #333; min-height: 100vh; }
        .navbar { background-color: var(--bank-blue); border-bottom: 3px solid var(--bank-gold); box-shadow: 0 2px 12px rgba(0,0,0,.15); }
        .navbar-brand { font-size: 1.4rem; font-weight: 800; letter-spacing: 2px; color: white !important; }
        .navbar-brand span { color: var(--bank-gold); }
        .nav-link { color: rgba(255,255,255,.85) !important; font-weight: 500; transition: color .2s; }
        .nav-link:hover { color: var(--bank-gold) !important; }
        .btn-bank { background: var(--bank-blue); color: white; border: none; padding: 10px 20px; font-weight: 600; transition: background .2s; }
        .btn-bank:hover { background: #001a4d; color: white; }
        footer { background-color: var(--bank-blue); color: rgba(255,255,255,.7); padding: 18px 0; margin-top: 60px; font-size: .85rem; border-top: 2px solid var(--bank-gold); }
        footer span { color: var(--bank-gold); font-weight: 700; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">NEON<span>BANK</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="navbar-nav ms-auto align-items-center">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
                        <a class="nav-link" asp-controller="Banking" asp-action="Dashboard"><i class="bi bi-arrow-left-right me-1"></i>Transfer</a>
                        <a class="nav-link" asp-controller="Banking" asp-action="RequestLoan"><i class="bi bi-bank me-1"></i>Loan</a>
                        <a class="nav-link" asp-controller="Banking" asp-action="TransactionHistory"><i class="bi bi-list-ul me-1"></i>Statement</a>
                        <a class="nav-link" asp-controller="Banking" asp-action="Profile"><i class="bi bi-person-circle me-1"></i>Profile</a>
                        <a class="nav-link" asp-controller="Banking" asp-action="ContactSupport"><i class="bi bi-headset me-1"></i>Support</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a class="nav-link text-warning" asp-controller="Banking" asp-action="SupportInbox"><i class="bi bi-envelope me-1"></i>Inbox</a>
                            <a class="nav-link text-warning border-start ms-2 ps-3" asp-controller="Banking" asp-action="AdminDashboard"><i class="bi bi-shield-lock me-1"></i>Admin</a>
                        }
                        <span class="nav-link text-white border-start ms-2 ps-3"><i class="bi bi-person-check me-1"></i>@User.Identity.Name</span>
                        <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
                    }
                    else
                    {
                        <a class="nav-link" asp-controller="Account" asp-action="Register"><i class="bi bi-person-plus me-1"></i>Open Account</a>
                        <a class="nav-link" asp-controller="Account" asp-action="Login"><i class="bi bi-lock me-1"></i>Login</a>
                    }
                </div>
            </div>
        </div>
    </nav>
    <div class="container mb-5">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="text-center">
        <div class="container">
            <span>NEONBANK</span> &copy; @DateTime.Now.Year &mdash; Secure Institutional Banking. All rights reserved.
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
